# 服务器配置
PORT=4173
HOST=0.0.0.0
NODE_ENV=development

# 数据存储 (json 或 sqlite)
DATA_STORE=json
SQLITE_PATH=/opt/nexai20x-data/app.sqlite

# 后台登录
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# 支付模式 (mock 或 live)
PAYMENT_MODE=mock

# 支付宝配置 (PAYMENT_MODE=live 时需要)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=

# 微信支付配置 (PAYMENT_MODE=live 时需要)
WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_API_V3_KEY=
WECHAT_PRIVATE_KEY=
WECHAT_SERIAL_NO=
WECHAT_PLATFORM_PUBLIC_KEY=
WECHAT_NOTIFY_URL=

# USDT 配置
USDT_BEP20_ADDRESS=
